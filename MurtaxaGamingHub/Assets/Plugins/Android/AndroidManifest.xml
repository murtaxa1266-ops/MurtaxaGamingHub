<?xml version="1.0" encoding="utf-8"?>
<!--
  AndroidManifest.xml
  Place in: Assets/Plugins/Android/
  
  Custom Android manifest for Murtaxa Gaming Hub.
  Optimized for mid-range Android devices, portrait + landscape support.
-->
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.murtaxagaming.hub"
    android:versionCode="1"
    android:versionName="1.0.0"
    android:installLocation="auto">

    <!-- ── Permissions ──────────────────────────────────────── -->
    <!-- Vibration for haptic feedback on combat/UI -->
    <uses-permission android:name="android.permission.VIBRATE"/>
    <!-- Wake lock: keeps screen on during gameplay -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <!-- Internet only if you add leaderboards/analytics later -->
    <!-- <uses-permission android:name="android.permission.INTERNET"/> -->

    <!-- ── Feature Requirements ─────────────────────────────── -->
    <!-- OpenGL ES 3.0 required (Unity URP minimum) -->
    <uses-feature android:glEsVersion="0x00030000" android:required="true"/>
    <!-- Touch screen required -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="true"/>
    <!-- Accelerometer optional (not required for this game) -->
    <uses-feature android:name="android.hardware.sensor.accelerometer" android:required="false"/>

    <application
        android:label="Murtaxa Gaming Hub"
        android:icon="@mipmap/app_icon"
        android:theme="@style/UnityThemeSelector"
        android:hardwareAccelerated="false"
        android:allowBackup="false"
        android:requestLegacyExternalStorage="true">

        <activity
            android:name="com.unity3d.player.UnityPlayerActivity"
            android:label="Murtaxa Gaming Hub"
            android:screenOrientation="landscape"
            android:launchMode="singleTask"
            android:configChanges="mcc|mnc|locale|touchscreen|keyboard|keyboardHidden|navigation|orientation|screenLayout|uiMode|screenSize|smallestScreenSize|fontScale|layoutDirection|density"
            android:resizeableActivity="false"
            android:exported="true">

            <!-- App Entry Point -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

            <!-- Performance: keep screen on -->
            <meta-data android:name="android.app.lib_name" android:value="unity"/>

        </activity>

        <!-- ── Unity Performance Metadata ────────────────────── -->

        <!-- Disable Unity's batched rendering for better low-poly performance -->
        <meta-data
            android:name="unityplayer.ForwardNativeEventsToDalvik"
            android:value="false"/>

        <!-- 60 FPS target -->
        <meta-data
            android:name="unityplayer.UnityActivity"
            android:value="true"/>

    </application>

    <!-- ── SDK Versions ─────────────────────────────────────── -->
    <!-- minSdkVersion 23 = Android 6.0 (covers ~99% of Android market) -->
    <!-- targetSdkVersion 33 = Android 13 (recommended for 2024 Play Store) -->
    <uses-sdk
        android:minSdkVersion="23"
        android:targetSdkVersion="33"/>

</manifest>
